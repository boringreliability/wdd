{
  "project": "wdd",
  "version": "0.1.0",
  "methodology": "wdd",
  "wdd_version": "1.2",
  "ai_tools": {
    "primary": "claude-code",
    "review": []
  },
  "conventions": {
    "test_framework": "node --test",
    "lint": "tsc --noEmit",
    "format": "prettier --check"
  },
  "ward_prefix": "ward",
  "ward_digits": 3,
  "scan": {
    "roots": [
      "src/"
    ],
    "extensions": [
      ".ts",
      ".tsx"
    ],
    "exclude": [
      "**/*.test.ts",
      "**/*.spec.ts",
      "**/*.test.tsx",
      "**/*.spec.tsx",
      "**/*.d.ts",
      "**/dist/**",
      "**/build/**",
      "**/node_modules/**"
    ]
  }
}